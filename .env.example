# === LLM Providers ===
# OpenAI-compatible (also works with OpenRouter, Groq, etc.)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# OpenAI-compatible base URL (for local proxies, Azure, etc.)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# Local model endpoint (Ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# === Database ===
DATABASE_URL=postgresql://openfinch:openfinch@postgres:5432/openfinch

# === Redis ===
REDIS_URL=redis://redis:6379

# === Search ===
SEARXNG_URL=http://searxng:8080

# === Storage (MinIO) ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=openfinch
MINIO_SECRET_KEY=openfinch-secret
MINIO_BUCKET=openfinch-artifacts
MINIO_USE_SSL=false

# === Server ===
API_PORT=8787
MCP_PORT=8788
DASHBOARD_PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# === Browser ===
MAX_BROWSER_SESSIONS=2
BROWSER_SESSION_TTL_SECONDS=300
BROWSER_HEADLESS=true

# === Agent ===
MAX_AGENT_STEPS=20
MAX_AGENT_RUNTIME_SECONDS=180
DEFAULT_AGENT_MODEL=claude-sonnet-4-6

# === Rate Limiting ===
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_SECONDS=60

# === Safety ===
RESPECT_ROBOTS_TXT=true
