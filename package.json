{
  "name": "openfinch",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source self-hosted AI web agent infrastructure",
  "type": "module",
  "overrides": {
    "esbuild": "^0.24.2"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -F @openfinch/api dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "clean": "pnpm -r clean",
    "demo:site": "node examples/demo-site/server.js",
    "smoke": "node tests/smoke/smoke.js",
    "smoke:local": "node tests/smoke/smoke-local.js",
    "smoke:docker": "node tests/smoke/smoke-docker.js",
    "smoke:dashboard": "node tests/smoke/dashboard-smoke.js",
    "verify:cookbook": "node tests/smoke/verify-cookbook.js",
    "test:e2e": "node tests/smoke/smoke-docker.js",
    "bench": "node tests/bench/bench.js",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "docs:dev": "cd site && pnpm dev",
    "docs:build": "cd site && pnpm build",
    "docs:preview": "cd site && pnpm preview"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.23.0"
}
