{
  "name": "@openfinch/cli",
  "version": "0.1.0",
  "description": "OpenFinch CLI — command-line interface for self-hosted AI web agent infrastructure",
  "type": "module",
  "bin": {
    "openfinch": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@openfinch/schemas": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "openfinch",
    "cli",
    "web-agent",
    "ai",
    "browser-automation",
    "self-hosted"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JonusNattapong/openfinch.git"
  },
  "bugs": {
    "url": "https://github.com/JonusNattapong/openfinch/issues"
  },
  "homepage": "https://github.com/JonusNattapong/openfinch#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
