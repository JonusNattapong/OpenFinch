{
  "name": "openfinch",
  "version": "0.1.0",
  "description": "OpenFinch JS SDK — self-hosted AI web agent infrastructure",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "openfinch",
    "web-agent",
    "ai",
    "browser-automation",
    "self-hosted",
    "web-scraping",
    "llm",
    "playwright"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openfinch/openfinch.git"
  },
  "bugs": {
    "url": "https://github.com/openfinch/openfinch/issues"
  },
  "homepage": "https://github.com/openfinch/openfinch#readme",
  "engines": {
    "node": ">=22.12.0"
  }
}
